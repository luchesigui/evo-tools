{
  "name": "evo-match-making",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make install",
        "cwd": "packages/evo-match-making"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make start",
        "cwd": "packages/evo-match-making"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make clean",
        "cwd": "packages/evo-match-making"
      }
    }
  }
}
